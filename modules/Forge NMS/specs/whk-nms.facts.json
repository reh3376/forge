{
  "specification_id": "whk-nms-v0.1.0",
  "specification_type": "adapter_registration",
  "title": "WHK NMS Adapter Specification",
  "description": "Forge adapter for the Whiskey House Network Management System (NMS) — a FastAPI+Next.js+Neo4j+TimescaleDB enterprise NMS providing network infrastructure visibility, SNMP monitoring, security event integration, and SPOF detection.",
  "version": "0.1.0",
  "effective_date": "2026-04-07",
  "author": "Engineering & Technology (Patrick Mannion)",
  "status": "draft",
  "adapter": {
    "adapter_id": "whk-nms",
    "name": "Whiskey House Network Management System Adapter",
    "description": "Ingests network infrastructure state (devices, topology, SNMP events, alerts, security events, anomalies, SPOF detections) via REST polling + WebSocket streaming.",
    "version": "0.1.0",
    "type": "INGESTION",
    "protocol": "rest+websocket",
    "tier": "MES_MOM",
    "capabilities": {
      "read": true,
      "write": false,
      "subscribe": true,
      "backfill": true,
      "discover": true
    }
  },
  "data_sources": [
    {
      "name": "Devices",
      "description": "Discovered network devices (717+)",
      "rest_endpoint": "/api/v1/devices",
      "method": "GET",
      "paginated": true,
      "entity_type": "ManufacturingUnit",
      "event_type": "device_discovery"
    },
    {
      "name": "Device Details",
      "description": "Detailed device information by ID",
      "rest_endpoint": "/api/v1/devices/{id}",
      "method": "GET",
      "paginated": false,
      "entity_type": "ManufacturingUnit",
      "event_type": "device_detail"
    },
    {
      "name": "Device Statistics",
      "description": "Device inventory statistics summary",
      "rest_endpoint": "/api/v1/devices/stats/summary",
      "method": "GET",
      "paginated": false,
      "entity_type": "OperationalEvent",
      "event_type": "device_stats"
    },
    {
      "name": "Interfaces",
      "description": "Network interfaces for a device",
      "rest_endpoint": "/api/v1/interfaces/{device_id}",
      "method": "GET",
      "paginated": false,
      "entity_type": "ManufacturingUnit",
      "event_type": "interface_inventory"
    },
    {
      "name": "Physical Links",
      "description": "Physical links from LLDP discovery (411+ links)",
      "rest_endpoint": "/api/v1/lldp/links",
      "method": "GET",
      "paginated": true,
      "entity_type": "OperationalEvent",
      "event_type": "link_discovered"
    },
    {
      "name": "Topology Graph",
      "description": "Subnet-based topology graph from Neo4j",
      "rest_endpoint": "/api/v1/topology/graph",
      "method": "GET",
      "paginated": false,
      "entity_type": "OperationalEvent",
      "event_type": "topology_snapshot"
    },
    {
      "name": "SNMP Traps",
      "description": "SNMP trap events from devices (via polling + WebSocket)",
      "rest_endpoint": "/api/v1/snmp/traps",
      "method": "GET",
      "paginated": true,
      "websocket_subscription": "/api/v1/events/stream",
      "entity_type": "OperationalEvent",
      "event_type": "snmp_trap"
    },
    {
      "name": "Alerts",
      "description": "Infrastructure alert rules and triggered events",
      "rest_endpoint": "/api/v1/alerts/rules",
      "method": "GET",
      "paginated": true,
      "entity_type": "OperationalEvent",
      "event_type": "infrastructure_alert"
    },
    {
      "name": "Security Events",
      "description": "FortiAnalyzer security events (threats, blocks, anomalies)",
      "rest_endpoint": "/api/v1/security/events",
      "method": "GET",
      "paginated": true,
      "entity_type": "OperationalEvent",
      "event_type": "security_event"
    },
    {
      "name": "SPOF Active",
      "description": "Active single points of failure in network topology",
      "rest_endpoint": "/api/v1/spof/active",
      "method": "GET",
      "paginated": false,
      "entity_type": "OperationalEvent",
      "event_type": "spof_detection"
    },
    {
      "name": "SPOF Summary",
      "description": "SPOF statistics and summary",
      "rest_endpoint": "/api/v1/spof/summary",
      "method": "GET",
      "paginated": false,
      "entity_type": "OperationalEvent",
      "event_type": "spof_summary"
    },
    {
      "name": "Baseline Devices",
      "description": "Devices with baseline anomalies (suspicious/blocked)",
      "rest_endpoint": "/api/v1/baseline/devices",
      "method": "GET",
      "paginated": true,
      "entity_type": "OperationalEvent",
      "event_type": "baseline_anomaly"
    },
    {
      "name": "SNMP Configuration",
      "description": "SNMP configuration for a specific device",
      "rest_endpoint": "/api/v1/snmp/config/{device_id}",
      "method": "GET",
      "paginated": false,
      "entity_type": "OperationalEvent",
      "event_type": "snmp_config"
    },
    {
      "name": "Event Stream",
      "description": "Real-time event stream for traps, alerts, anomalies",
      "websocket_endpoint": "/api/v1/events/stream",
      "entity_type": "OperationalEvent",
      "event_type": "event_stream"
    }
  ],
  "domain_mappings": [
    {
      "nms_entity": "discovered_hosts",
      "forge_model": "ManufacturingUnit",
      "unit_type": "network_device",
      "mapping": {
        "id": "source_id",
        "ip_address": "equipment_id (primary) or embedded in context",
        "name": "implicit in context",
        "type": "product_type",
        "device_metadata.serial_number": "serial_number (or mac_address fallback)",
        "device_metadata.vendor": "product_type (vendor + model)",
        "health_status": "status (mapped to UnitStatus)"
      }
    },
    {
      "nms_entity": "trap_events",
      "forge_model": "OperationalEvent",
      "event_type": "snmp_trap",
      "mapping": {
        "id": "source_id",
        "device_id": "entity_id",
        "trap_type": "event_subtype",
        "oid": "context.extra.oid",
        "severity": "severity",
        "trap_time": "event_time",
        "context": "from build_record_context()"
      }
    },
    {
      "nms_entity": "alerts",
      "forge_model": "OperationalEvent",
      "event_type": "infrastructure_alert",
      "mapping": {
        "id": "source_id",
        "device_id": "entity_id",
        "name": "event_subtype",
        "condition": "result",
        "severity": "severity",
        "triggered_at": "event_time"
      }
    },
    {
      "nms_entity": "security_events",
      "forge_model": "OperationalEvent",
      "event_type": "security_event",
      "mapping": {
        "id": "source_id",
        "device_id": "entity_id",
        "event_type": "event_subtype",
        "threat_type": "event_subtype",
        "severity": "severity",
        "event_time": "event_time",
        "action_taken": "result"
      }
    },
    {
      "nms_entity": "baseline_anomalies",
      "forge_model": "OperationalEvent",
      "event_type": "baseline_anomaly",
      "mapping": {
        "device_id": "source_id + entity_id",
        "baseline_status": "event_subtype",
        "suspicious_reason": "result",
        "anomaly_detected_at": "event_time"
      }
    },
    {
      "nms_entity": "spof_detection",
      "forge_model": "OperationalEvent",
      "event_type": "spof_detection",
      "mapping": {
        "device_id": "source_id + entity_id",
        "spof_type": "event_subtype",
        "blast_radius": "context.extra.blast_radius",
        "affected_services": "result",
        "detected_at": "event_time"
      }
    }
  ],
  "connection_requirements": [
    {
      "name": "nms_api_url",
      "type": "url",
      "required": true,
      "description": "REST API base URL (e.g. http://localhost:8000/api/v1)",
      "example": "http://localhost:8000/api/v1"
    },
    {
      "name": "nms_ws_url",
      "type": "url",
      "required": false,
      "description": "WebSocket URL for event streaming (optional, defaults to REST polling only)",
      "example": "ws://localhost:8000/api/v1/events/stream"
    },
    {
      "name": "jwt_token",
      "type": "secret",
      "required": false,
      "description": "JWT bearer token for authenticated requests (optional, defaults to anonymous)"
    },
    {
      "name": "poll_interval_seconds",
      "type": "integer",
      "required": false,
      "default": 60,
      "description": "Polling interval for REST endpoints"
    },
    {
      "name": "verify_ssl",
      "type": "boolean",
      "required": false,
      "default": true,
      "description": "Verify SSL certificates for HTTPS"
    }
  ],
  "context_fields": [
    "cross_system_id",
    "source_system",
    "entity_type",
    "event_type",
    "operation_context",
    "device_ip",
    "device_type",
    "device_role",
    "device_category",
    "is_critical",
    "is_ot_device",
    "location",
    "severity",
    "health_status",
    "poll_tier",
    "network_role",
    "blast_radius",
    "baseline_status"
  ],
  "quality_rules": [
    {
      "name": "device_id_required",
      "entity_type": "ManufacturingUnit",
      "rule": "Device mapping requires at least 'id' or 'ip_address' field",
      "enforcement": "warn"
    },
    {
      "name": "event_id_required",
      "entity_type": "OperationalEvent",
      "rule": "Event mapping requires at least 'id' field",
      "enforcement": "error"
    },
    {
      "name": "timestamp_preferred",
      "entity_type": "OperationalEvent",
      "rule": "Event should include timestamp; defaults to now(utc) if missing",
      "enforcement": "warn"
    },
    {
      "name": "device_category_derived",
      "entity_type": "OperationalEvent",
      "rule": "device_category is auto-mapped from device_type if not provided",
      "enforcement": "info"
    }
  ],
  "known_limitations": [
    {
      "limitation": "Phase 1 (inject-only) — no live API connections",
      "mitigation": "Phase 2 will implement actual REST polling and WebSocket streaming"
    },
    {
      "limitation": "No backfill in Phase 1",
      "mitigation": "Phase 2 will support historical data retrieval from NMS"
    },
    {
      "limitation": "WebSocket subscription optional",
      "mitigation": "If WS URL not provided, adapter falls back to REST polling only"
    },
    {
      "limitation": "NMS read-only (no write operations)",
      "mitigation": "Future phases may support device config changes or alert management"
    }
  ],
  "decision_quality_value": {
    "summary": "Network infrastructure visibility correlated with manufacturing operations",
    "examples": [
      "Identify which critical OT devices have baseline anomalies or security events",
      "Calculate SPOF impact on production if key network devices fail",
      "Correlate network outages with production downtime and quality issues",
      "Monitor OT/IT device health trends during critical production windows",
      "Audit network changes against change management workflows"
    ]
  }
}
