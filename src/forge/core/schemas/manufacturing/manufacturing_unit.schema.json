{
  "$defs": {
    "LifecycleState": {
      "description": "Granular lifecycle phase within a manufacturing unit's journey.\n\nDerived from ISA-88 batch states and WMS barrel disposition.",
      "enum": [
        "CREATED",
        "FILLING",
        "IN_PROCESS",
        "AGING",
        "IN_STORAGE",
        "IN_TRANSIT",
        "SAMPLING",
        "WITHDRAWN",
        "DUMPED",
        "COMPLETE"
      ],
      "title": "LifecycleState",
      "type": "string"
    },
    "UnitStatus": {
      "description": "Lifecycle status of a manufacturing unit (barrel, batch, tank).",
      "enum": [
        "PENDING",
        "ACTIVE",
        "COMPLETE",
        "HELD",
        "SCRAPPED",
        "TRANSFERRED"
      ],
      "title": "UnitStatus",
      "type": "string"
    }
  },
  "description": "A discrete, trackable container of product.\n\nThe unit_type distinguishes barrels from batches from tanks.\nAdapters set this to their source concept name.",
  "properties": {
    "forge_id": {
      "description": "Forge-internal unique identifier.",
      "format": "uuid",
      "title": "Forge Id",
      "type": "string"
    },
    "source_system": {
      "description": "Adapter or system that produced this record (e.g. 'whk-wms').",
      "title": "Source System",
      "type": "string"
    },
    "source_id": {
      "description": "Primary key of this entity in the source system.",
      "title": "Source Id",
      "type": "string"
    },
    "captured_at": {
      "description": "UTC timestamp when this snapshot was captured by Forge.",
      "format": "date-time",
      "title": "Captured At",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "Source-system-specific fields that don't map to core schema.",
      "title": "Metadata",
      "type": "object"
    },
    "unit_type": {
      "description": "Source concept type (e.g. 'barrel', 'batch', 'tank').",
      "title": "Unit Type",
      "type": "string"
    },
    "serial_number": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Unique serial identifier if applicable (e.g. barrel serial).",
      "title": "Serial Number"
    },
    "lot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to the associated Lot (by source_id).",
      "title": "Lot Id"
    },
    "location_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to current PhysicalAsset location (by source_id).",
      "title": "Location Id"
    },
    "owner_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to owning BusinessEntity (by source_id).",
      "title": "Owner Id"
    },
    "recipe_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reference to ProcessDefinition used (by source_id).",
      "title": "Recipe Id"
    },
    "status": {
      "$ref": "#/$defs/UnitStatus",
      "default": "PENDING",
      "description": "High-level lifecycle status."
    },
    "lifecycle_state": {
      "anyOf": [
        {
          "$ref": "#/$defs/LifecycleState"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Granular lifecycle phase within the unit's journey."
    },
    "quantity": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Current quantity (volume, weight, count).",
      "title": "Quantity"
    },
    "unit_of_measure": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Unit of measure for quantity (e.g. 'gallons', 'kg').",
      "title": "Unit Of Measure"
    },
    "product_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Product classification (e.g. whiskey type, grade).",
      "title": "Product Type"
    }
  },
  "required": [
    "source_system",
    "source_id",
    "unit_type"
  ],
  "title": "ManufacturingUnit",
  "type": "object"
}
