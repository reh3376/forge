{
  "spec_version": "0.1.0",
  "endpoint": "/v1/schemas/{schema_id}/compatibility",
  "method": "POST",
  "authentication": {
    "required": true,
    "schemes": ["bearer", "api_key"]
  },
  "request": {
    "content_type": "application/json"
  },
  "response": {
    "success_status": 200,
    "error_format": {
      "type": "rfc7807"
    },
    "max_latency_ms": 1000
  },
  "rate_limit": {
    "requests_per_minute": 60,
    "burst": 10
  }
}
