{
  "spec_version": "0.1.0",
  "endpoint": "/v1/info",
  "method": "GET",
  "authentication": {
    "required": false,
    "schemes": ["bearer", "api_key", "none"]
  },
  "request": {},
  "response": {
    "success_status": 200,
    "error_format": {
      "type": "rfc7807"
    },
    "max_latency_ms": 500
  },
  "rate_limit": {
    "requests_per_minute": 60,
    "burst": 10
  }
}
