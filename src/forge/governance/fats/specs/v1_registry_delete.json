{
  "spec_version": "0.1.0",
  "endpoint": "/v1/schemas/{schema_id}",
  "method": "DELETE",
  "authentication": {
    "required": true,
    "schemes": ["bearer", "api_key"]
  },
  "request": {},
  "response": {
    "success_status": 204,
    "error_format": {
      "type": "rfc7807"
    },
    "max_latency_ms": 2000
  },
  "rate_limit": {
    "requests_per_minute": 30,
    "burst": 5
  }
}
