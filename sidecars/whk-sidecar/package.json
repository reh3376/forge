{
  "name": "@forge/whk-sidecar",
  "version": "0.1.0",
  "description": "Forge spoke sidecar for WHK systems (WMS + MES) — gRPC bridge to hub",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "proto:generate": "buf generate ../../src/forge/proto --template ../../src/forge/proto/buf.gen.yaml",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "google-protobuf": "^3.21.0",
    "graphql-request": "^7.0.0",
    "mqtt": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/google-protobuf": "^3.15.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "ts-proto": "^1.176.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
