+            connection_name_template="{connection}",
+        ),
+    ],
+)
+
+
+# ---------------------------------------------------------------------------
+# DiscreteValve
+# ---------------------------------------------------------------------------
+
+
+DISCRETE_VALVE = TagTemplate(
+    name="DiscreteValve",
