+        assert stats["total_tags"] == 7
+        assert stats["by_type"]["standard"] == 5
+        assert stats["by_type"]["memory"] == 1
+        assert stats["by_type"]["expression"] == 1
+        assert stats["dependency_edges"] >= 1
