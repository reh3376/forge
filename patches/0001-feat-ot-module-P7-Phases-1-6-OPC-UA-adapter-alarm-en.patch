+
+    def test_analog_instrument_instantiation(self, builtin_reg):
+        tags = builtin_reg.instantiate(
+            "AnalogInstrument",
+            "TIT_2010",
+            {
+                "connection": "WHK01",
+                "base_path": "Distillery01",
+                "tag_id": "TIT_2010",
+                "units": "°F",
+                "area": "Distillery",
